name: diamonds-price-prediction
conda_env: conda.yaml

entry_points:
  main:
    parameters:
      test_size: {type: float, default: 0.2}
      random_state: {type: int, default: 42}
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 10}
    command: "python modelling.py --test_size {test_size} --random_state {random_state} --n_estimators {n_estimators} --max_depth {max_depth}"
  
  tuning:
    parameters:
      test_size: {type: float, default: 0.2}
      random_state: {type: int, default: 42}
      n_iter: {type: int, default: 10}
    command: "python modelling.py --tuning --test_size {test_size} --random_state {random_state} --n_iter {n_iter}"
